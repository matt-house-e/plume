{
  "name": "plume",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --filter=@plume/web",
    "dev:studio": "turbo run dev --filter=@plume/studio",
    "build": "turbo run build",
    "preview": "turbo run preview --filter=@plume/web",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,astro,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
