---
const currentYear = new Date().getFullYear()

const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/work', label: 'Work' },
  { href: '/contact', label: 'Contact' },
]
---

<footer class="border-t border-border bg-surface">
  <div class="max-w-6xl mx-auto px-6 md:px-8 py-16 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-8">
      <div class="md:col-span-5">
        <a href="/" class="inline-block font-semibold text-xl tracking-tight text-foreground">
          plume<span class="text-accent">.</span>
        </a>
      </div>

      <div class="md:col-span-3 md:col-start-8">
        <h4 class="font-mono text-xs uppercase tracking-[0.2em] text-muted mb-4">Navigation</h4>
        <nav class="flex flex-col gap-3">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm text-muted hover:text-foreground transition-colors duration-200"
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-border flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-muted-foreground">
        &copy; {currentYear} All rights reserved.
      </p>
    </div>
  </div>
</footer>
