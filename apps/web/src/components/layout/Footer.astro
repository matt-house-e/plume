---
const currentYear = new Date().getFullYear()

const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/work', label: 'Work' },
  { href: '/contact', label: 'Contact' },
]
---

<footer class="relative border-t border-border bg-surface">
  <!-- Gradient accent line at top -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent/50 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-6 md:px-8 py-16 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-8">
      <!-- Brand Column -->
      <div class="md:col-span-5">
        <a href="/" class="inline-block">
          <span class="font-semibold text-xl tracking-tight text-foreground">
            plume<span class="text-accent">.</span>
          </span>
        </a>
        <p class="mt-4 text-muted text-sm leading-relaxed max-w-sm">
          A modern portfolio starter built with Astro, React, Tailwind, and Sanity.
          Replace this with your own tagline.
        </p>
      </div>

      <!-- Navigation Column -->
      <div class="md:col-span-3 md:col-start-8">
        <h4 class="font-mono text-xs uppercase tracking-[0.2em] text-muted mb-4">
          Navigation
        </h4>
        <nav class="flex flex-col gap-3">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm text-muted hover:text-foreground transition-colors duration-200"
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Contact Column -->
      <div class="md:col-span-3">
        <h4 class="font-mono text-xs uppercase tracking-[0.2em] text-muted mb-4">
          Get in touch
        </h4>
        <a
          href="mailto:hello@example.com"
          class="text-sm text-foreground hover:text-accent transition-colors duration-200"
        >
          hello@example.com
        </a>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-16 pt-8 border-t border-border flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-muted-foreground">
        &copy; {currentYear} Your Name. All rights reserved.
      </p>
      <p class="text-xs text-muted-foreground">
        Built with <span class="text-accent">Astro</span> + <span class="text-accent">React</span>
      </p>
    </div>
  </div>
</footer>
