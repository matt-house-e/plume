---
import BaseLayout from '../layouts/BaseLayout.astro'
import Button from '../components/primitives/Button'
import ScrollReveal from '../components/animations/ScrollReveal'
---

<BaseLayout
  title="Contact | Plume"
  description="Get in touch. Replace with your own contact page description."
>
  <!-- Hero Section -->
  <section class="py-20 md:py-32">
    <div class="max-w-6xl mx-auto px-6 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        <!-- Content -->
        <div>
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-accent animate-fade-up">Contact</span>
          <h1 class="mt-4 text-4xl md:text-5xl font-bold tracking-tight text-foreground animate-fade-up stagger-1">
            Let's work together
          </h1>
          <p class="mt-6 text-lg text-muted leading-relaxed animate-fade-up stagger-2">
            Replace this with your own contact page introduction. Tell visitors
            why they should reach out and what to expect.
          </p>

          <!-- Contact Info -->
          <div class="mt-12 space-y-6 animate-fade-up stagger-3">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-accent-muted text-accent">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-foreground">Email</h3>
                <a href="mailto:hello@example.com" class="text-muted hover:text-accent transition-colors">
                  hello@example.com
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-accent-muted text-accent">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-foreground">GitHub</h3>
                <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-accent transition-colors">
                  github.com/yourname
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-accent-muted text-accent">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-foreground">LinkedIn</h3>
                <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-accent transition-colors">
                  linkedin.com/in/yourname
                </a>
              </div>
            </div>
          </div>

          <!-- Response time -->
          <div class="mt-12 p-6 bg-surface-elevated border border-border rounded-xl animate-fade-up stagger-4">
            <div class="flex items-center gap-3">
              <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
              <span class="text-sm text-muted">
                Typically responds within 24 hours
              </span>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="animate-fade-up stagger-2">
          <form class="space-y-6 bg-surface-elevated border border-border rounded-2xl p-8">
            <div>
              <label for="name" class="block font-mono text-xs uppercase tracking-[0.15em] text-muted mb-2">
                Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 bg-surface border border-border rounded-xl text-foreground placeholder-muted-foreground focus:outline-none focus:border-accent/50 focus:ring-2 focus:ring-accent/20 transition-all"
                placeholder="Your name"
              />
            </div>

            <div>
              <label for="email" class="block font-mono text-xs uppercase tracking-[0.15em] text-muted mb-2">
                Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 bg-surface border border-border rounded-xl text-foreground placeholder-muted-foreground focus:outline-none focus:border-accent/50 focus:ring-2 focus:ring-accent/20 transition-all"
                placeholder="you@example.com"
              />
            </div>

            <div>
              <label for="subject" class="block font-mono text-xs uppercase tracking-[0.15em] text-muted mb-2">
                Subject
              </label>
              <select
                id="subject"
                name="subject"
                class="w-full px-4 py-3 bg-surface border border-border rounded-xl text-foreground focus:outline-none focus:border-accent/50 focus:ring-2 focus:ring-accent/20 transition-all"
              >
                <option value="">Select a subject</option>
                <option value="project">New Project</option>
                <option value="collaboration">Collaboration</option>
                <option value="general">General Inquiry</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block font-mono text-xs uppercase tracking-[0.15em] text-muted mb-2">
                Message
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 bg-surface border border-border rounded-xl text-foreground placeholder-muted-foreground focus:outline-none focus:border-accent/50 focus:ring-2 focus:ring-accent/20 transition-all resize-none"
                placeholder="Tell me about your project..."
              ></textarea>
            </div>

            <Button type="submit" className="w-full">
              Send message
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
              </svg>
            </Button>

            <p class="text-xs text-muted-foreground text-center">
              This form is for demonstration purposes. Connect a form service to make it functional.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-24 md:py-32 border-t border-border">
    <div class="max-w-6xl mx-auto px-6 md:px-8">
      <div class="mb-16">
        <span class="font-mono text-xs uppercase tracking-[0.2em] text-accent">FAQ</span>
        <h2 class="mt-4 text-3xl md:text-4xl font-bold tracking-tight text-foreground">
          Common questions
        </h2>
      </div>

      <ScrollReveal client:visible className="grid grid-cols-1 md:grid-cols-2 gap-8" stagger={0.1}>
        <div class="p-8 bg-surface-elevated border border-border rounded-2xl card-hover">
          <h3 class="font-semibold text-foreground mb-3">Question one goes here?</h3>
          <p class="text-sm text-muted leading-relaxed">
            Replace with your answer. Keep it concise and helpful.
          </p>
        </div>

        <div class="p-8 bg-surface-elevated border border-border rounded-2xl card-hover">
          <h3 class="font-semibold text-foreground mb-3">Question two goes here?</h3>
          <p class="text-sm text-muted leading-relaxed">
            Replace with your answer. Keep it concise and helpful.
          </p>
        </div>

        <div class="p-8 bg-surface-elevated border border-border rounded-2xl card-hover">
          <h3 class="font-semibold text-foreground mb-3">Question three goes here?</h3>
          <p class="text-sm text-muted leading-relaxed">
            Replace with your answer. Keep it concise and helpful.
          </p>
        </div>

        <div class="p-8 bg-surface-elevated border border-border rounded-2xl card-hover">
          <h3 class="font-semibold text-foreground mb-3">Question four goes here?</h3>
          <p class="text-sm text-muted leading-relaxed">
            Replace with your answer. Keep it concise and helpful.
          </p>
        </div>
      </ScrollReveal>
    </div>
  </section>
</BaseLayout>
