---
import BaseLayout from '../layouts/BaseLayout.astro'
import Button from '../components/primitives/Button'
import ScrollReveal from '../components/animations/ScrollReveal'

const services = [
  {
    title: 'Service One',
    description: 'Describe your first service or skill here. What do you offer and why does it matter?',
    icon: '◇',
  },
  {
    title: 'Service Two',
    description: 'Describe your second service or skill here. What problem does it solve for clients?',
    icon: '⬡',
  },
  {
    title: 'Service Three',
    description: 'Describe your third service or skill here. What makes your approach unique?',
    icon: '△',
  },
  {
    title: 'Service Four',
    description: 'Describe your fourth service or skill here. What results can clients expect?',
    icon: '○',
  },
]

const projects = [
  {
    title: 'Project One',
    description: 'A brief description of this project and what it achieved.',
    technologies: ['Tech A', 'Tech B', 'Tech C'],
    category: 'Category',
  },
  {
    title: 'Project Two',
    description: 'A brief description of this project and what it achieved.',
    technologies: ['Tech A', 'Tech B', 'Tech C'],
    category: 'Category',
  },
  {
    title: 'Project Three',
    description: 'A brief description of this project and what it achieved.',
    technologies: ['Tech A', 'Tech B', 'Tech C'],
    category: 'Category',
  },
]
---

<BaseLayout>
  <!-- Hero Section -->
  <section class="relative min-h-[90vh] flex items-center">
    <div class="max-w-6xl mx-auto px-6 md:px-8 py-20 md:py-32">
      <div class="max-w-4xl">
        <!-- Label -->
        <div class="animate-fade-up">
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-accent-muted border border-accent/20 text-accent text-sm font-medium">
            <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
            Available for projects
          </span>
        </div>

        <!-- Headline -->
        <h1 class="mt-8 text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight text-foreground leading-[1.1] animate-fade-up stagger-1">
          Your headline goes
          <span class="text-gradient-accent"> right here</span>
        </h1>

        <!-- Subheadline -->
        <p class="mt-6 md:mt-8 text-lg md:text-xl text-muted max-w-2xl leading-relaxed animate-fade-up stagger-2">
          A short description of who you are and what you do. Replace this with
          your own elevator pitch — keep it to two or three lines.
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-wrap gap-4 animate-fade-up stagger-3">
          <Button href="/contact" size="lg">
            Get in touch
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </Button>
          <Button href="/work" variant="secondary" size="lg">
            View my work
          </Button>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-fade-in stagger-5">
      <div class="flex flex-col items-center gap-2 text-muted">
        <span class="text-xs font-mono uppercase tracking-widest">Scroll</span>
        <div class="w-px h-8 bg-gradient-to-b from-muted to-transparent"></div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-24 md:py-32 border-t border-border">
    <div class="max-w-6xl mx-auto px-6 md:px-8">
      <!-- Section Header -->
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
        <div>
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-accent">Services</span>
          <h2 class="mt-4 text-3xl md:text-4xl font-bold tracking-tight text-foreground">
            What I do
          </h2>
        </div>
        <a href="/services" class="text-sm text-muted hover:text-foreground transition-colors link-underline">
          View all services &rarr;
        </a>
      </div>

      <!-- Services Grid -->
      <ScrollReveal client:visible className="grid grid-cols-1 md:grid-cols-2 gap-6" stagger={0.1}>
        {services.map((service) => (
          <div class="group p-8 bg-surface-elevated border border-border rounded-2xl card-hover">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-accent-muted text-accent text-xl">
                {service.icon}
              </div>
              <div class="flex-1">
                <h3 class="text-lg font-semibold text-foreground group-hover:text-accent transition-colors">
                  {service.title}
                </h3>
                <p class="mt-2 text-sm text-muted leading-relaxed">
                  {service.description}
                </p>
              </div>
            </div>
          </div>
        ))}
      </ScrollReveal>
    </div>
  </section>

  <!-- Featured Work Section -->
  <section class="py-24 md:py-32 border-t border-border">
    <div class="max-w-6xl mx-auto px-6 md:px-8">
      <!-- Section Header -->
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
        <div>
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-accent">Featured Work</span>
          <h2 class="mt-4 text-3xl md:text-4xl font-bold tracking-tight text-foreground">
            Recent projects
          </h2>
        </div>
        <a href="/work" class="text-sm text-muted hover:text-foreground transition-colors link-underline">
          View all projects &rarr;
        </a>
      </div>

      <!-- Projects Grid -->
      <ScrollReveal client:visible className="grid grid-cols-1 md:grid-cols-3 gap-6" stagger={0.15}>
        {projects.map((project) => (
          <div class="group relative bg-surface-elevated border border-border rounded-2xl overflow-hidden card-hover">
            <!-- Project Image Placeholder -->
            <div class="aspect-[4/3] bg-gradient-to-br from-accent/10 via-surface to-cyan/5 flex items-center justify-center">
              <div class="w-16 h-16 rounded-2xl bg-accent/20 flex items-center justify-center">
                <span class="text-accent text-2xl">&#x2B21;</span>
              </div>
            </div>

            <div class="p-6">
              <!-- Category -->
              <span class="font-mono text-xs uppercase tracking-[0.15em] text-accent">
                {project.category}
              </span>

              <h3 class="mt-3 text-lg font-semibold text-foreground group-hover:text-accent transition-colors">
                {project.title}
              </h3>

              <p class="mt-2 text-sm text-muted leading-relaxed">
                {project.description}
              </p>

              <!-- Technologies -->
              <div class="mt-4 flex flex-wrap gap-2">
                {project.technologies.map((tech) => (
                  <span class="px-2 py-1 text-xs font-mono text-muted bg-surface border border-border rounded">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </ScrollReveal>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 md:py-32 border-t border-border">
    <div class="max-w-6xl mx-auto px-6 md:px-8">
      <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-surface-elevated to-surface border border-border p-12 md:p-16">
        <!-- Background Glow -->
        <div class="absolute top-0 right-0 w-96 h-96 bg-accent/10 rounded-full blur-[100px]"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-cyan/10 rounded-full blur-[80px]"></div>

        <div class="relative z-10 max-w-2xl">
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-accent">Let's work together</span>
          <h2 class="mt-4 text-3xl md:text-4xl font-bold tracking-tight text-foreground">
            Have a project in mind?
          </h2>
          <p class="mt-4 text-lg text-muted leading-relaxed">
            Replace this with your own call-to-action. Tell potential clients
            or collaborators why they should reach out.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <Button href="/contact" size="lg">
              Get in touch
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </Button>
            <Button href="mailto:hello@example.com" variant="secondary" size="lg">
              hello@example.com
            </Button>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
