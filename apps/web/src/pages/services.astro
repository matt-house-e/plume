---
import BaseLayout from '../layouts/BaseLayout.astro'
import Button from '../components/primitives/Button'
import ScrollReveal from '../components/animations/ScrollReveal'

const services = [
  {
    title: 'Service One',
    description: 'Describe this service in detail. What does it include? Who is it for? What outcomes can clients expect?',
    features: [
      'Feature or deliverable one',
      'Feature or deliverable two',
      'Feature or deliverable three',
      'Feature or deliverable four',
      'Feature or deliverable five',
    ],
    icon: '◇',
  },
  {
    title: 'Service Two',
    description: 'Describe this service in detail. What does it include? Who is it for? What outcomes can clients expect?',
    features: [
      'Feature or deliverable one',
      'Feature or deliverable two',
      'Feature or deliverable three',
      'Feature or deliverable four',
      'Feature or deliverable five',
    ],
    icon: '⬡',
  },
  {
    title: 'Service Three',
    description: 'Describe this service in detail. What does it include? Who is it for? What outcomes can clients expect?',
    features: [
      'Feature or deliverable one',
      'Feature or deliverable two',
      'Feature or deliverable three',
      'Feature or deliverable four',
      'Feature or deliverable five',
    ],
    icon: '△',
  },
  {
    title: 'Service Four',
    description: 'Describe this service in detail. What does it include? Who is it for? What outcomes can clients expect?',
    features: [
      'Feature or deliverable one',
      'Feature or deliverable two',
      'Feature or deliverable three',
      'Feature or deliverable four',
      'Feature or deliverable five',
    ],
    icon: '○',
  },
]

const process = [
  {
    step: '01',
    title: 'Discovery',
    description: 'Describe the first step of your process. What happens during this phase?',
  },
  {
    step: '02',
    title: 'Strategy',
    description: 'Describe the second step. How do you plan the work?',
  },
  {
    step: '03',
    title: 'Build',
    description: 'Describe the third step. How do you execute?',
  },
  {
    step: '04',
    title: 'Deliver',
    description: 'Describe the final step. How do you wrap up and hand off?',
  },
]
---

<BaseLayout
  title="Services | Plume"
  description="Services and expertise offered. Replace with your own description."
>
  <!-- Hero Section -->
  <section class="py-20 md:py-32">
    <div class="max-w-6xl mx-auto px-6 md:px-8">
      <div class="max-w-3xl">
        <span class="font-mono text-xs uppercase tracking-[0.2em] text-accent animate-fade-up">Services</span>
        <h1 class="mt-4 text-4xl md:text-5xl font-bold tracking-tight text-foreground animate-fade-up stagger-1">
          What I can do for you
        </h1>
        <p class="mt-6 text-lg text-muted leading-relaxed animate-fade-up stagger-2">
          A short overview of your services. Replace this with a description
          of how you help clients and what makes your approach different.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-24 md:py-32 border-t border-border">
    <div class="max-w-6xl mx-auto px-6 md:px-8">
      <ScrollReveal client:visible className="space-y-24" stagger={0}>
        {services.map((service, index) => (
          <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 ${index % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
            <div class={index % 2 === 1 ? 'lg:order-2' : ''}>
              <div class="flex items-center gap-4 mb-6">
                <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-accent-muted text-accent text-xl">
                  {service.icon}
                </div>
                <span class="font-mono text-xs uppercase tracking-[0.15em] text-muted">
                  Service 0{index + 1}
                </span>
              </div>
              <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-foreground">
                {service.title}
              </h2>
              <p class="mt-4 text-muted leading-relaxed">
                {service.description}
              </p>
              <Button href="/contact" variant="secondary" className="mt-8">
                Discuss this service
              </Button>
            </div>

            <div class={`bg-surface-elevated border border-border rounded-2xl p-8 ${index % 2 === 1 ? 'lg:order-1' : ''}`}>
              <h3 class="font-mono text-xs uppercase tracking-[0.15em] text-accent mb-6">
                What's included
              </h3>
              <ul class="space-y-4">
                {service.features.map((feature) => (
                  <li class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-accent mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    <span class="text-foreground">{feature}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </ScrollReveal>
    </div>
  </section>

  <!-- Process Section -->
  <section class="py-24 md:py-32 border-t border-border">
    <div class="max-w-6xl mx-auto px-6 md:px-8">
      <div class="mb-16">
        <span class="font-mono text-xs uppercase tracking-[0.2em] text-accent">Process</span>
        <h2 class="mt-4 text-3xl md:text-4xl font-bold tracking-tight text-foreground">
          How I work
        </h2>
      </div>

      <ScrollReveal client:visible className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8" stagger={0.1}>
        {process.map((step) => (
          <div class="relative">
            <span class="text-5xl font-bold text-accent/20">{step.step}</span>
            <h3 class="mt-4 text-lg font-semibold text-foreground">{step.title}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{step.description}</p>
          </div>
        ))}
      </ScrollReveal>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 md:py-32 border-t border-border">
    <div class="max-w-6xl mx-auto px-6 md:px-8">
      <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-surface-elevated to-surface border border-border p-12 md:p-16 text-center">
        <div class="absolute top-0 right-0 w-96 h-96 bg-accent/10 rounded-full blur-[100px]"></div>

        <div class="relative z-10 max-w-2xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground">
            Ready to get started?
          </h2>
          <p class="mt-4 text-lg text-muted">
            Replace this with your own call-to-action copy.
          </p>
          <div class="mt-8">
            <Button href="/contact" size="lg">
              Get in touch
            </Button>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
